# ==========================================
# BuildEstate Admin Panel Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values


# ===========================================
# BACKEND API CONFIGURATION
# ===========================================
# Backend API URL - Must match your deployed backend

# For local development:
VITE_BACKEND_URL=http://localhost:4000

# For production (replace with your actual backend URL):
# VITE_BACKEND_URL=https://your-backend-domain.onrender.com
# VITE_BACKEND_URL=https://your-backend-domain.herokuapp.com
# VITE_BACKEND_URL=https://your-custom-domain.com


# ===========================================
# ADMIN PANEL CONFIGURATION
# ===========================================
# Admin panel title and branding
VITE_APP_NAME="BuildEstate Admin"
VITE_APP_VERSION="1.0.0"

# Company information for branding
VITE_COMPANY_NAME="BuildEstate"
VITE_COMPANY_LOGO_URL="/logo.png"


# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable/disable specific admin features
VITE_ENABLE_USER_MANAGEMENT=true
VITE_ENABLE_BULK_OPERATIONS=true
VITE_ENABLE_ACTIVITY_LOGS=true
VITE_ENABLE_EMAIL_BROADCAST=true


# ===========================================
# DEPLOYMENT SPECIFIC
# ===========================================
# Admin panel URL (for email links, etc.)
VITE_ADMIN_URL=http://localhost:5174

# Frontend website URL (for "View Site" links)
VITE_FRONTEND_URL=http://localhost:5173


# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================
# Sentry for error monitoring (optional)
# Get from https://sentry.io/
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Help documentation URL
VITE_HELP_URL=https://github.com/your-repo/wiki/admin-guide