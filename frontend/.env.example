# ==========================================
# BuildEstate Frontend Environment Variables
# ==========================================
# Copy this file to .env and fill in your actual values


# ===========================================
# BACKEND API CONFIGURATION
# ===========================================
# Backend API URL - Change this based on your deployment

# For local development:
VITE_API_BASE_URL=http://localhost:4000

# For production (replace with your actual backend URL):
# VITE_API_BASE_URL=https://your-backend-domain.onrender.com
# VITE_API_BASE_URL=https://your-backend-domain.herokuapp.com
# VITE_API_BASE_URL=https://your-custom-domain.com


# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable AI Property Hub features (optional)
# Set to "true" to show AI Hub in navigation
# Set to "false" or leave unset to hide AI features
VITE_ENABLE_AI_HUB=true

# Enable user property listings (set to false for read-only site)
VITE_ENABLE_USER_LISTINGS=true

# Enable appointments/bookings feature
VITE_ENABLE_APPOINTMENTS=true


# ===========================================
# ANALYTICS & MONITORING (Optional)
# ===========================================
# Google Analytics 4 Measurement ID
# Get from https://analytics.google.com/
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Hotjar Site ID for user behavior analytics
# Get from https://www.hotjar.com/
# VITE_HOTJAR_SITE_ID=your_hotjar_site_id


# ===========================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ===========================================
# Google Maps API Key (for location features)
# Get from https://console.cloud.google.com/
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay/Stripe for payments (if implementing premium features)
# VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key


# ===========================================
# DEPLOYMENT SPECIFIC
# ===========================================
# Site URL for SEO and sharing (used in meta tags)
VITE_SITE_URL=http://localhost:5173

# Contact information
VITE_CONTACT_EMAIL=contact@buildestate.com
VITE_CONTACT_PHONE=+1-234-567-8900

# Social media links (for footer/sharing)
VITE_SOCIAL_INSTAGRAM=https://instagram.com/buildestate
VITE_SOCIAL_TWITTER=https://twitter.com/buildestate
VITE_SOCIAL_FACEBOOK=https://facebook.com/buildestate